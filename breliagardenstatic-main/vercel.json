{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/produtos",              "destination": "/produtos.html" },
    { "source": "/sobre",                 "destination": "/sobre.html" },
    { "source": "/contato",               "destination": "/contato.html" },
    { "source": "/produto-box-rosas",     "destination": "/produto-box-rosas.html" },
    { "source": "/produto-buque-misto",   "destination": "/produto-buque-misto.html" },
    { "source": "/produto-orquidea",      "destination": "/produto-orquidea.html" },
    { "source": "/produto-cesta-romantica", "destination": "/produto-cesta-romantica.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
